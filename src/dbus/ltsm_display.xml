<?xml version="1.0" encoding="UTF-8"?>

<node name="/ltsm/session/display">
    <interface name="LTSM.Session.Display">

        <!-- methods -->
        <method name="getVersion">
            <arg type="i" name="version" direction="out" />
        </method>

        <method name="serviceShutdown">
        </method>

        <method name="setDebug">
            <arg type="s" name="level" direction="in" />
        </method>

        <method name="setSessionKeyboardLayout">
            <arg type="s" name="layout" direction="in" />
        </method>

        <method name="runSessionZenity">
            <arg type="as" name="args" direction="in" />
            <arg type="(iay)" name="statusStdout" direction="out" />
        </method>

        <method name="runSessionCommandSync">
            <arg type="s" name="cmd" direction="in" />
            <arg type="as" name="args" direction="in" />
            <arg type="as" name="envs" direction="in" />
            <arg type="(iay)" name="statusStdout" direction="out" />
        </method>

        <method name="runSessionCommandAsync">
            <arg type="s" name="cmd" direction="in" />
            <arg type="as" name="args" direction="in" />
            <arg type="as" name="envs" direction="in" />
            <arg type="i" name="pid" direction="out" />
        </method>

        <method name="jsonStatus">
            <arg type="s" name="json" direction="out" />
        </method>

        <method name="notifyInfo">
            <arg type="s" name="summary" direction="in" />
            <arg type="s" name="body" direction="in" />
        </method>

        <method name="notifyWarning">
            <arg type="s" name="summary" direction="in" />
            <arg type="s" name="body" direction="in" />
        </method>

        <method name="notifyError">
            <arg type="s" name="summary" direction="in" />
            <arg type="s" name="body" direction="in" />
        </method>

        <method name="audioChannelConnect">
            <arg type="s" name="socketPath" direction="in" />
            <arg type="b" name="res" direction="out" />
        </method>

        <method name="audioChannelDisconnect">
            <arg type="s" name="socketPath" direction="in" />
        </method>

        <method name="pcscChannelConnect">
            <arg type="s" name="socketPath" direction="in" />
            <arg type="b" name="res" direction="out" />
        </method>

        <method name="pcscChannelDisconnect">
            <arg type="s" name="socketPath" direction="in" />
        </method>

        <method name="fuseMountPoint">
            <arg type="s" name="localPoint" direction="in" />
            <arg type="s" name="remotePoint" direction="in" />
            <arg type="s" name="fuseSocket" direction="in" />
            <arg type="b" name="res" direction="out" />
        </method>

        <method name="fuseUmountPoint">
            <arg type="s" name="localPoint" direction="in" />
        </method>

        <!-- signals -->        
        <signal name="runSessionCommandAsyncComplete">
            <arg type="i" name="pid" />
            <arg type="b" name="success" />
            <arg type="i" name="wstatus" />
            <arg type="ay" name="stdout" />
        </signal>

    </interface>
</node>
